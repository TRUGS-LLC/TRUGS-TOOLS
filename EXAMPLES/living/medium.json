{
  "name": "Living Medium Example",
  "version": "1.0.0",
  "type": "LIVING",
  "branch": "living",
  "description": "Medium living TRUG: a query triggers two tool executions, extracts an entity, and produces an answer",
  "nodes": [
    {
      "id": "query_1",
      "type": "QUERY",
      "metric_level": "BASE_QUERY",
      "parent_id": null,
      "properties": {
        "name": "stock_analysis_query",
        "text": "What is the current price and 30-day trend for AAPL?",
        "intent": "financial_analysis"
      }
    },
    {
      "id": "tool_price",
      "type": "TOOL_EXECUTION",
      "metric_level": "CENTI_TOOL_EXECUTION",
      "parent_id": "query_1",
      "properties": {
        "name": "fetch_price",
        "tool": "stock_price_api",
        "parameters": {
          "ticker": "AAPL"
        },
        "status": "completed"
      }
    },
    {
      "id": "tool_trend",
      "type": "TOOL_EXECUTION",
      "metric_level": "CENTI_TOOL_EXECUTION",
      "parent_id": "query_1",
      "properties": {
        "name": "fetch_trend",
        "tool": "stock_history_api",
        "parameters": {
          "ticker": "AAPL",
          "period": "30d"
        },
        "status": "completed"
      }
    },
    {
      "id": "entity_price",
      "type": "ENTITY",
      "metric_level": "MILLI_ENTITY",
      "parent_id": "query_1",
      "properties": {
        "name": "aapl_current_price",
        "entity_type": "stock_price",
        "value": {
          "price": 189.5,
          "currency": "USD"
        },
        "source": "stock_price_api"
      }
    },
    {
      "id": "answer_1",
      "type": "ANSWER",
      "metric_level": "BASE_ANSWER",
      "parent_id": "query_1",
      "properties": {
        "name": "stock_analysis_answer",
        "text": "AAPL is currently trading at $189.50 with a +5.2% trend over the past 30 days.",
        "confidence": 0.95
      }
    }
  ],
  "edges": [
    {
      "from_id": "query_1",
      "to_id": "tool_price",
      "relation": "contains"
    },
    {
      "from_id": "query_1",
      "to_id": "tool_trend",
      "relation": "contains"
    },
    {
      "from_id": "query_1",
      "to_id": "entity_price",
      "relation": "contains"
    },
    {
      "from_id": "query_1",
      "to_id": "answer_1",
      "relation": "contains"
    },
    {
      "from_id": "query_1",
      "to_id": "tool_price",
      "relation": "triggers"
    },
    {
      "from_id": "query_1",
      "to_id": "tool_trend",
      "relation": "triggers"
    },
    {
      "from_id": "tool_price",
      "to_id": "entity_price",
      "relation": "produces"
    },
    {
      "from_id": "entity_price",
      "to_id": "answer_1",
      "relation": "builds_on"
    },
    {
      "from_id": "tool_trend",
      "to_id": "answer_1",
      "relation": "builds_on"
    },
    {
      "from_id": "answer_1",
      "to_id": "entity_price",
      "relation": "cites"
    }
  ],
  "dimensions": [
    {
      "name": "memory_flow",
      "levels": [
        "QUERY",
        "TOOL_EXECUTION",
        "ENTITY",
        "SYNTHESIS",
        "ANSWER"
      ]
    }
  ]
}
